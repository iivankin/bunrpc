{
  "name": "@bunrpc/core",
  "version": "0.1.13",
  "description": "Type-safe RPC core for Bun",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iivankin/bunrpc.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/iivankin/bunrpc#readme",
  "bugs": {
    "url": "https://github.com/iivankin/bunrpc/issues"
  },
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./standard-schema": "./src/standard-schema.ts"
  },
  "files": [
    "src",
    "LICENSE",
    "README.md",
    "!src/**/*.test.ts"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "typescript": "6.0.2"
  }
}
