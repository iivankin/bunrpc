{
  "name": "@bunrpc/openapi",
  "version": "0.1.7",
  "description": "OpenAPI plugin for @bunrpc/core",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iivankin/bunrpc.git",
    "directory": "packages/openapi"
  },
  "homepage": "https://github.com/iivankin/bunrpc#readme",
  "bugs": {
    "url": "https://github.com/iivankin/bunrpc/issues"
  },
  "keywords": [
    "bun",
    "rpc",
    "openapi",
    "swagger"
  ],
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "LICENSE",
    "README.md",
    "!src/**/*.test.ts"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run test"
  },
  "dependencies": {
    "@bunrpc/core": "^0.1.7"
  },
  "devDependencies": {
    "@types/bun": "1.3.9",
    "typescript": "5.9.3"
  }
}
