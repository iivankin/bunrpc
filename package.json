{
  "name": "bunrpc",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iivankin/bunrpc.git"
  },
  "homepage": "https://github.com/iivankin/bunrpc#readme",
  "bugs": {
    "url": "https://github.com/iivankin/bunrpc/issues"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "fix": "ultracite fix",
    "check": "ultracite check",
    "typecheck": "bun run --parallel --filter '*' --if-present typecheck",
    "test": "bun run --parallel --filter '*' --if-present test",
    "prepare": "lefthook install --reset-hooks-path"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "lefthook": "2.1.4",
    "ultracite": "7.4.0"
  }
}
